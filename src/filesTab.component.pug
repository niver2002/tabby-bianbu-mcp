div(style='height:100%;display:flex;flex-direction:column;background:rgba(30,30,30,.96);color:#e4e4e4;font-family:"Segoe UI Variable","Segoe UI",system-ui,-apple-system,sans-serif;font-size:13px;overflow:hidden')
  //- Toolbar
  .toolbar(style='display:flex;align-items:center;gap:6px;padding:6px 12px;background:rgba(255,255,255,.04);border-bottom:1px solid rgba(255,255,255,.06);flex-shrink:0;min-height:40px')
    .btn-group(style='display:flex;gap:2px;background:rgba(255,255,255,.06);border-radius:6px;padding:2px')
      button(type='button', (click)='goBack()', [disabled]='historyIndex <= 0', style='background:none;border:none;color:#e4e4e4;padding:4px 8px;border-radius:4px;cursor:pointer;font-size:14px;opacity:.8', title='Back') ←
      button(type='button', (click)='goForward()', [disabled]='historyIndex >= history.length - 1', style='background:none;border:none;color:#e4e4e4;padding:4px 8px;border-radius:4px;cursor:pointer;font-size:14px;opacity:.8', title='Forward') →
      button(type='button', (click)='goUp()', [disabled]='currentPath === "." || currentPath === "/"', style='background:none;border:none;color:#e4e4e4;padding:4px 8px;border-radius:4px;cursor:pointer;font-size:14px;opacity:.8', title='Up') ↑
    .breadcrumbs(style='display:flex;align-items:center;gap:2px;flex:1;min-width:0;background:rgba(255,255,255,.05);border-radius:6px;padding:0 8px;height:30px;overflow:hidden')
      span(*ngFor='let crumb of breadcrumbs; let i = index', (click)='navigateBreadcrumb(i)', style='cursor:pointer;padding:2px 4px;border-radius:3px;white-space:nowrap;opacity:.85;font-size:12px', [style.font-weight]='i === breadcrumbs.length - 1 ? "600" : "400"')
        | {{ crumb }}
        span(*ngIf='i < breadcrumbs.length - 1', style='opacity:.4;margin-left:4px') ›
    input#bianbu-path-input(type='text', [(ngModel)]='pathInput', (keyup.enter)='navigateToInput()', placeholder='Enter path…', style='width:200px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.08);border-radius:6px;padding:4px 10px;color:#e4e4e4;font-size:12px;height:30px;outline:none')
    .btn-group(style='display:flex;gap:2px;background:rgba(255,255,255,.06);border-radius:6px;padding:2px')
      button(type='button', (click)='refresh()', style='background:none;border:none;color:#e4e4e4;padding:4px 8px;border-radius:4px;cursor:pointer;font-size:13px;opacity:.8', title='Refresh (F5)') ⟳
      button(type='button', (click)='openCreateFilePrompt()', style='background:none;border:none;color:#e4e4e4;padding:4px 8px;border-radius:4px;cursor:pointer;font-size:13px;opacity:.8', title='New file (Ctrl+N)') +📄
      button(type='button', (click)='openCreateDirectoryPrompt()', style='background:none;border:none;color:#e4e4e4;padding:4px 8px;border-radius:4px;cursor:pointer;font-size:13px;opacity:.8', title='New folder (Ctrl+Shift+N)') +📁
    label(style='background:rgba(255,255,255,.06);border-radius:6px;padding:4px 10px;cursor:pointer;font-size:12px;height:30px;display:flex;align-items:center;gap:4px;opacity:.85')
      | ⬆ Upload
      input(type='file', multiple, (change)='uploadFile($event)', style='display:none')
    button(type='button', (click)='toggleDetailPane()', style='background:none;border:none;color:#e4e4e4;padding:4px 8px;border-radius:4px;cursor:pointer;font-size:13px;opacity:.8', [style.opacity]='detailPaneVisible ? "1" : ".5"', title='Toggle preview') ☰
    label(style='display:flex;align-items:center;gap:4px;margin-left:4px;opacity:.7;font-size:11px;cursor:pointer')
      input(type='checkbox', [(ngModel)]='asRoot', (ngModelChange)='refresh()')
      | root

  //- Search bar
  .search-bar(style='display:flex;align-items:center;gap:8px;padding:4px 12px;flex-shrink:0')
    input(type='text', [(ngModel)]='searchText', (ngModelChange)='applyFilter()', placeholder='🔍 Filter files…', style='flex:1;max-width:280px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.06);border-radius:6px;padding:4px 10px;color:#e4e4e4;font-size:12px;height:28px;outline:none')
    span(style='opacity:.5;font-size:11px;white-space:nowrap') {{ filteredItems.length }} items
    span(*ngIf='selectionSummary', style='opacity:.5;font-size:11px') • {{ selectionSummary }}
    span(style='opacity:.5;font-size:11px;margin-left:auto') {{ totalSize }}

  //- Main content
  .main(style='flex:1;display:flex;overflow:hidden')
    //- File list pane
    .file-list-pane(style='flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:300px', (dragover)='onDragOver($event)', (dragleave)='onDragLeave()', (drop)='onDrop($event)')
      //- Drop overlay
      div(*ngIf='dragActive', style='position:absolute;inset:0;z-index:10;background:rgba(74,222,128,.12);display:flex;align-items:center;justify-content:center;border:2px dashed rgba(74,222,128,.5);border-radius:8px;pointer-events:none')
        span(style='font-size:16px;color:#4ade80') Drop files to upload

      //- Table header
      .table-header(style='display:flex;padding:0 12px;background:rgba(255,255,255,.03);border-bottom:1px solid rgba(255,255,255,.06);flex-shrink:0;user-select:none')
        span(style='flex:5;padding:6px 4px;cursor:pointer;font-size:12px;font-weight:600;opacity:.7', (click)='toggleSort("name")') Name{{ sortIndicator('name') }}
        span(style='flex:1.5;padding:6px 4px;cursor:pointer;font-size:12px;font-weight:600;opacity:.7;text-align:right', (click)='toggleSort("size")') Size{{ sortIndicator('size') }}
        span(style='flex:2.5;padding:6px 4px;cursor:pointer;font-size:12px;font-weight:600;opacity:.7', (click)='toggleSort("date")') Modified{{ sortIndicator('date') }}
        span(style='flex:1.2;padding:6px 4px;cursor:pointer;font-size:12px;font-weight:600;opacity:.7', (click)='toggleSort("type")') Type{{ sortIndicator('type') }}

      //- File list
      .file-list(style='flex:1;overflow-y:auto;overflow-x:hidden')
        div(*ngFor='let item of filteredItems; let i = index', (click)='selectItem(item, $event)', (dblclick)='openItem(item)', (contextmenu)='showContextMenu($event, item)', style='display:flex;padding:0 12px;cursor:default;border-bottom:1px solid rgba(255,255,255,.02);transition:background .1s', [style.background]='isSelected(i) ? "rgba(98,100,167,.35)" : "transparent"')
          span(style='flex:5;padding:5px 4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:flex;align-items:center;gap:6px')
            span(style='font-size:15px;flex-shrink:0') {{ fileIcon(item) }}
            span(style='font-weight:500') {{ baseName(item.path) }}
          span(style='flex:1.5;padding:5px 4px;opacity:.6;text-align:right;font-variant-numeric:tabular-nums') {{ item.is_dir ? '—' : formatSize(item.size) }}
          span(style='flex:2.5;padding:5px 4px;opacity:.5;font-variant-numeric:tabular-nums') {{ formatDate(item.modified) }}
          span(style='flex:1.2;padding:5px 4px;opacity:.5') {{ fileType(item) }}

        //- Empty state
        div(*ngIf='!filteredItems.length && !busy', style='padding:40px;text-align:center;opacity:.4')
          div(style='font-size:32px;margin-bottom:8px') 📂
          div {{ searchText ? 'No matches' : 'Empty directory' }}

    //- Preview/Detail pane
    .detail-pane(*ngIf='detailPaneVisible', style='width:340px;border-left:1px solid rgba(255,255,255,.06);display:flex;flex-direction:column;flex-shrink:0;background:rgba(255,255,255,.02)')
      .detail-header(style='padding:10px 14px;border-bottom:1px solid rgba(255,255,255,.06);display:flex;align-items:center;gap:8px;flex-shrink:0')
        span(style='font-size:18px') {{ selectedItem ? fileIcon(selectedItem) : '📄' }}
        span(style='font-weight:600;font-size:13px;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap') {{ selectedPath ? baseName(selectedPath) : 'No selection' }}
        button(*ngIf='selectedPath', type='button', (click)='downloadSelected()', style='background:rgba(255,255,255,.08);border:none;color:#e4e4e4;padding:3px 8px;border-radius:4px;cursor:pointer;font-size:11px') ⬇
        button(*ngIf='selectedPath && selectedIsText', type='button', (click)='saveSelected()', style='background:rgba(59,130,246,.6);border:none;color:white;padding:3px 8px;border-radius:4px;cursor:pointer;font-size:11px') Save

      .detail-content(style='flex:1;overflow:auto;padding:0')
        textarea(*ngIf='selectedPath && selectedIsText', [(ngModel)]='selectedContent', style='width:100%;height:100%;background:transparent;border:none;color:#d4d4d8;font-family:"Cascadia Code","Fira Code","JetBrains Mono",monospace;font-size:12px;padding:10px 14px;resize:none;outline:none;line-height:1.5;tab-size:4;box-sizing:border-box')
        div(*ngIf='selectedPath && !selectedIsText', style='padding:30px;text-align:center;opacity:.5')
          div(style='font-size:28px;margin-bottom:8px') {{ selectedItem ? fileIcon(selectedItem) : '📄' }}
          div Binary file
          button(type='button', (click)='downloadSelected()', style='margin-top:12px;background:rgba(255,255,255,.08);border:none;color:#e4e4e4;padding:6px 16px;border-radius:6px;cursor:pointer;font-size:12px') Download
        div(*ngIf='!selectedPath', style='padding:30px;text-align:center;opacity:.3')
          div(style='font-size:28px;margin-bottom:8px') 👆
          div(style='font-size:12px') Select a file to preview

  //- Status bar
  .status-bar(style='display:flex;align-items:center;gap:12px;padding:4px 12px;background:rgba(255,255,255,.03);border-top:1px solid rgba(255,255,255,.06);flex-shrink:0;font-size:11px;opacity:.6;min-height:24px')
    span {{ status }}
    span(*ngIf='transfers.length', (click)='transfersVisible = !transfersVisible', style='margin-left:auto;cursor:pointer;opacity:.8') {{ transfers.filter(t => t.status === 'running' || t.status === 'queued').length ? '⬆⬇ ' + transfers.filter(t => t.status === 'running' || t.status === 'queued').length + ' active' : '✓ Transfers done' }}

  //- Context menu
  div(*ngIf='contextMenuVisible', style='position:fixed;z-index:100;background:rgba(45,45,45,.98);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:4px;min-width:160px;backdrop-filter:blur(16px);box-shadow:0 8px 32px rgba(0,0,0,.4)', [style.left.px]='contextMenuX', [style.top.px]='contextMenuY')
    button(type='button', (click)='openItem(contextItem); hideContextMenu()', style='display:block;width:100%;text-align:left;background:none;border:none;color:#e4e4e4;padding:6px 12px;border-radius:4px;cursor:pointer;font-size:12px') Open
    button(type='button', (click)='openRenamePrompt(contextItem); hideContextMenu()', style='display:block;width:100%;text-align:left;background:none;border:none;color:#e4e4e4;padding:6px 12px;border-radius:4px;cursor:pointer;font-size:12px') Rename
    div(style='height:1px;background:rgba(255,255,255,.08);margin:2px 8px')
    button(type='button', (click)='deleteItem(contextItem); hideContextMenu()', style='display:block;width:100%;text-align:left;background:none;border:none;color:#f87171;padding:6px 12px;border-radius:4px;cursor:pointer;font-size:12px') Delete

  //- Prompt overlay
  div(*ngIf='promptVisible', style='position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px)')
    div(style='background:rgba(45,45,45,.98);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:24px;width:380px;box-shadow:0 16px 48px rgba(0,0,0,.5)')
      h3(style='margin:0 0 16px 0;font-size:15px;font-weight:600') {{ promptTitle }}
      input(type='text', [(ngModel)]='promptValue', (keyup.enter)='confirmPrompt()', (keyup.escape)='closePrompt()', autofocus, style='width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:6px;padding:8px 12px;color:#e4e4e4;font-size:13px;outline:none;box-sizing:border-box')
      div(style='display:flex;gap:8px;margin-top:16px;justify-content:flex-end')
        button(type='button', (click)='closePrompt()', style='background:rgba(255,255,255,.08);border:none;color:#e4e4e4;padding:6px 20px;border-radius:6px;cursor:pointer;font-size:12px') Cancel
        button(type='button', (click)='confirmPrompt()', style='background:rgba(59,130,246,.7);border:none;color:white;padding:6px 20px;border-radius:6px;cursor:pointer;font-size:12px') Confirm

  //- Transfers panel
  div(*ngIf='transfersVisible && transfers.length', style='position:fixed;right:16px;bottom:40px;width:380px;max-height:45vh;background:rgba(40,40,40,.98);border:1px solid rgba(255,255,255,.1);border-radius:12px;z-index:50;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,.4);backdrop-filter:blur(16px)')
    div(style='padding:10px 14px;border-bottom:1px solid rgba(255,255,255,.06);display:flex;align-items:center')
      span(style='font-weight:600;font-size:13px;flex:1') Transfers
      button(type='button', (click)='transfersVisible = false', style='background:none;border:none;color:#e4e4e4;cursor:pointer;font-size:16px;opacity:.6') ×
    div(style='overflow-y:auto;max-height:calc(45vh - 44px)')
      div(*ngFor='let transfer of transfers', style='padding:10px 14px;border-bottom:1px solid rgba(255,255,255,.04)')
        div(style='display:flex;align-items:center;gap:6px;margin-bottom:4px')
          span(style='font-size:11px') {{ transfer.direction === 'upload' ? '⬆' : '⬇' }}
          span(style='font-size:12px;font-weight:500;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap') {{ transfer.name }}
          span(style='font-size:10px;opacity:.5;padding:1px 6px;border-radius:3px;background:rgba(255,255,255,.06)') {{ transfer.status }}
          button(*ngIf='transfer.status === "running" || transfer.status === "queued"', type='button', (click)='cancelTransfer(transfer)', style='background:none;border:none;color:#f87171;cursor:pointer;font-size:11px;padding:2px 4px') ✕
        div(*ngIf='transfer.bytesTotal', style='height:3px;background:rgba(255,255,255,.08);border-radius:2px;overflow:hidden')
          div(style='height:100%;border-radius:2px;transition:width .2s', [style.width.%]='transferPercent(transfer) || 0', [style.background]='transfer.status === "error" ? "#f87171" : transfer.status === "done" ? "#4ade80" : "#3b82f6"')
        div(style='display:flex;gap:8px;margin-top:3px;font-size:10px;opacity:.4')
          span {{ formatSize(transfer.bytesDone) }} / {{ formatSize(transfer.bytesTotal) }}
          span {{ transferRate(transfer) }}
