div(style='padding: 20px; display:flex; flex-direction:column; gap:16px')
  .hero(style='padding:18px; border-radius:12px; background:linear-gradient(135deg, rgba(25,53,103,.9), rgba(17,94,89,.85)); color:white')
    h2(style='margin:0 0 8px 0') Bianbu MCP
    p(style='margin:0; opacity:.92')
      | Configure your Bianbu Cloud MCP endpoint and open a shell-like tab or a file-manager-like tab directly from Tabby.

  .card(style='padding:16px; border-radius:10px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08)')
    h3(style='margin-top:0') Quick actions
    div(style='display:flex; gap:12px; flex-wrap:wrap')
      button.btn.btn-primary(type='button', (click)='openShell()') Open Bianbu Cloud Shell
      button.btn.btn-secondary(type='button', (click)='openFiles()') Open Bianbu Cloud Files

  .card(style='padding:16px; border-radius:10px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08)')
    h3(style='margin-top:0') Connection settings
    .grid(style='display:grid; grid-template-columns: 160px 1fr; gap:12px; align-items:center')
      label Enable integration
      input(type='checkbox', [(ngModel)]='config.store.bianbuMcp.enabled', (ngModelChange)='save()')

      label Profile name
      input.form-control(type='text', [(ngModel)]='config.store.bianbuMcp.name', (ngModelChange)='save()', placeholder='bianbu')

      label MCP URL
      input.form-control(type='text', [(ngModel)]='config.store.bianbuMcp.url', (ngModelChange)='save()', placeholder='https://your-domain.example.com/mcp')

      label X-API-KEY
      input.form-control(type='password', [(ngModel)]='config.store.bianbuMcp.apiKey', (ngModelChange)='save()', placeholder='your-x-api-key')

      label Interval (ms)
      input.form-control(type='number', min='0', [(ngModel)]='config.store.bianbuMcp.minIntervalMs', (ngModelChange)='save()')

      label Max retries
      input.form-control(type='number', min='0', [(ngModel)]='config.store.bianbuMcp.maxRetries', (ngModelChange)='save()')

      label Retry base (ms)
      input.form-control(type='number', min='0', [(ngModel)]='config.store.bianbuMcp.retryBaseMs', (ngModelChange)='save()')

      label Notes
      textarea.form-control(rows='3', [(ngModel)]='config.store.bianbuMcp.notes', (ngModelChange)='save()', placeholder='Optional notes')

  .card(style='padding:16px; border-radius:10px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08)')
    h3(style='margin-top:0') Copyable MCP snippet
    pre(style='white-space: pre-wrap; margin-bottom:0') {{ sampleJson }}

  .card(style='padding:16px; border-radius:10px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08)')
    h3(style='margin-top:0') Reminder
    ul(style='margin-bottom:0')
      li MCP URL is typically #[code https://&lt;domain&gt;/mcp]
      li #[code X-API-KEY] is copied from the Bianbu Cloud API Key page
      li Shell and Files tabs are UI views backed by MCP calls, not native SSH/SFTP transport
