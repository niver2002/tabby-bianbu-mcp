{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2019",
    "declaration": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "newLine": "lf",
    "skipLibCheck": true,
    "strict": false,
    "lib": ["es2019", "dom"],
    "types": ["webpack-env"]
  },
  "include": ["src/**/*.ts"]
}
